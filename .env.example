GROQ_API_KEY=

MODEL_NAME=llama-3.3-70b-versatile

# Smaller/faster model used only for the input and output guardrail checks.
# llama-3.1-8b-instant has 5x higher TPM on Groq's free tier (30k vs 6k).
GUARDRAIL_MODEL=llama-3.1-8b-instant

MODEL_TEMPERATURE=0.0

# Windows example: C:\Users\yourname\Documents\my_docs
# Mac/Linux example: /home/yourname/docs
DOCUMENTS_DIR=

# Windows example: C:\Users\yourname\Projects\project\vector_store_dir
# Mac/Linux example: /home/yourname/project/vector_store_dir
VECTOR_STORE_DIR=

# ChromaDB collection name. Must match between ingestion and retrieval.
# Only change this if you want to maintain multiple separate collections.
COLLECTION_NAME=my_collection1

# URL the Streamlit frontend uses to call the FastAPI backend (non-streaming).
CHAT_ENDPOINT_URL=http://localhost:8000/chat/answer

# URL for the streaming endpoint used by the Streamlit frontend.
CHAT_STREAM_URL=http://localhost:8000/chat/stream

# Redis connection URL for the semantic cache.
REDIS_URL=redis://localhost:6379

# JWT Authentication
# Generate SECRET_KEY with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

ADMIN_USERNAME=admin
# Generate hash with: python -c "import bcrypt; print(bcrypt.hashpw('yourpassword'.encode(), bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=

LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGSMITH_API_KEY=
LANGCHAIN_PROJECT=rag-project

LOG_FORMAT=console
